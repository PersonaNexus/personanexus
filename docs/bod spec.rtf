    # See table below for full content \'96 10 entries\
\
  board_engagement_rules:\
    - "Convene on user queries"\
    - "Each member responds from their historical lens"\
    - "Synthesize consensus or majority vote"\
    - "Highlight conflicting viewpoints for balanced advice"\
